# Ferrumyx Web Interface Environment Configuration Examples

# Production Environment
# Copy this to .env and adjust values for production deployment
NODE_ENV=production
API_ENDPOINT=https://api.ferrumyx.com
CORS_ORIGIN=https://app.ferrumyx.com
CDN_URL=https://cdn.ferrumyx.com

# Staging Environment
# NODE_ENV=staging
# API_ENDPOINT=https://api-staging.ferrumyx.com
# CORS_ORIGIN=https://app-staging.ferrumyx.com
# CDN_URL=https://cdn-staging.ferrumyx.com

# Development Environment
# NODE_ENV=development
# API_ENDPOINT=http://localhost:3000
# CORS_ORIGIN=http://localhost:8080
# CDN_URL=

# Security Settings (add to nginx environment)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# ANALYTICS_ID=GA_MEASUREMENT_ID

# Docker Compose Environment Variables
# These are used when running with docker-compose
# COMPOSE_PROJECT_NAME=ferrumyx
# FERRUMYX_WEB_PORT=8080
# FERRUMYX_API_PORT=3000

# SSL/TLS Configuration (when using HTTPS)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Rate Limiting Configuration
# RATE_LIMIT_API=10r/s
# RATE_LIMIT_STATIC=100r/s

# Cache Configuration
# STATIC_CACHE_DURATION=1y
# HTML_CACHE_DURATION=1h