FROM rust:1.80-slim-bullseye AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y \
    libclang-dev \
    clang \
    build-essential \
    tcl \
    protobuf-compiler \
    file \
    libssl-dev \
    pkg-config \
    git \
    cmake \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy only Cargo.toml and Cargo.lock first for better caching
COPY Cargo.toml Cargo.lock ./

# Copy the source code
COPY crates/ ./crates/

# Build only the web server (skip tests and docs for faster build)
RUN cargo build --release -p ferrumyx-web --no-default-features

# Runtime stage
FROM debian:bullseye-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    libssl1.1 \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user
RUN useradd -r -s /bin/false ferrumyx

# Copy the built binary
COPY --from=builder /app/target/release/ferrumyx-web /usr/local/bin/ferrumyx-web

# Set proper ownership
RUN chown ferrumyx:ferrumyx /usr/local/bin/ferrumyx-web

# Switch to non-root user
USER ferrumyx

# Expose port
EXPOSE 3000

# Run the web server
CMD ["/usr/local/bin/ferrumyx-web"]
