# Ferrumyx v2.0.0 Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://ferrumyx:${POSTGRES_PASSWORD}@localhost:5432/ferrumyx
POSTGRES_PASSWORD=
POSTGRES_USER=ferrumyx
POSTGRES_DB=ferrumyx
READONLY_PASSWORD=

# Redis
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# Web Server
FERRUMYX_WEB_ADDR=0.0.0.0:3000
FERRUMYX_DATABASE_URL=postgresql://ferrumyx:${POSTGRES_PASSWORD}@postgres:5432/ferrumyx
FERRUMYX_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# IronClaw Agent
IRONCLAW_API_KEY=your_ironclaw_api_key
IRONCLAW_ENDPOINT=https://api.ironclaw.near.ai

# BioClaw Skills
BIOCLAW_WASM_PATH=./wasm
BIOCLAW_TOOLS_ENABLED=pubmed,blast,pymol,fastqc,fpocket,vina,rdkit,admet

# Multi-channel Gateway
SLACK_BOT_TOKEN=xoxb-your-slack-token
DISCORD_BOT_TOKEN=your-discord-token
WHATSAPP_API_KEY=your-whatsapp-key
WEBHOOK_SECRET=your-webhook-secret

# LLM API Keys (choose one or more)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
POE_API_KEY=...

# External APIs
PUBMED_API_KEY=
EUROPEPMC_API_KEY=

# Data Paths
DEPMAP_DATA_PATH=./data/depmap
LITERATURE_DATA_PATH=./data/literature
MOLECULAR_DATA_PATH=./data/molecular

# Security
ENCRYPTION_KEY=32-char-encryption-key-here
JWT_SECRET=your-jwt-secret-key
SESSION_SECRET=your-session-secret

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=
ALERTMANAGER_PORT=9093

# Logging
RUST_LOG=info,ferrumyx=debug,ironclaw=info
LOG_LEVEL=info

# Development
DEBUG=true
HOT_RELOAD=true

# Production
NODE_ENV=production
COMPOSE_PROJECT_NAME=ferrumyx-prod

# Secrets (Docker secrets in production)
DB_PASSWORD_FILE=/run/secrets/db_password
REDIS_PASSWORD_FILE=/run/secrets/redis_password
API_KEYS_FILE=/run/secrets/api_keys