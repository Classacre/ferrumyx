{
  "dashboard": {
    "id": null,
    "title": "Application Performance",
    "tags": ["ferrumyx", "application"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Response Time (95th percentile)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"ferrumyx-app\"}[5m]))",
            "legendFormat": "95th percentile"
          }
        ],
        "yaxes": [
          {
            "unit": "seconds"
          }
        ]
      },
      {
        "id": 2,
        "title": "Request Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"ferrumyx-app\"}[5m])",
            "legendFormat": "Requests/s"
          }
        ]
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"ferrumyx-app\", status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"ferrumyx-app\"}[5m]) * 100",
            "legendFormat": "Error %"
          }
        ],
        "yaxes": [
          {
            "unit": "percent"
          }
        ]
      },
      {
        "id": 4,
        "title": "Throughput",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"ferrumyx-app\"}[5m])",
            "legendFormat": "Requests/s"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    },
    "refresh": "5s",
    "schemaVersion": 16,
    "version": 0,
    "links": []
  }
}